usel.querySelectorAll('.carousel-card');\n  var total = cards.length;\n\n  // How many FULL cards fit in the usable width?\n  // Subtract 6 px (px-[3px] × 2) from offsetWidth to get the real display area.\n  var containerWidth = list.parentElement.offsetWidth;\n  var usableWidth    = containerWidth - 6;\n  var visibleAtStart = Math.floor((usableWidth + 8) / STEP); // (usable + gap) / STEP\n  var maxIndex       = Math.max(0, total - visibleAtStart);\n\n  // Build dots\n  for (var i = 0; i < total; i++) {\n    var dot = document.createElement('div');\n    dot.style.cssText = 'width:8px;height:8px;border-radius:50%;flex-shrink:0;cursor:pointer;';\n    dot.dataset.idx = i;\n    dotsWrap.appendChild(dot);\n  }\n  var dots = dotsWrap.querySelectorAll('div');\n\n  function goTo(idx) {\n    current = Math.max(0, Math.min(idx, maxIndex));\n    list.style.transition = 'transform 0.3s ease';\n    list.style.transform  = 'translateX(' + (-current * STEP) + 'px)';\n    dots.forEach(function (d, i) {\n      d.style.background = i === current ? '#30B57E' : '#AEBFD1';\n    });\n    if (arrowNext) arrowNext.style.display = current >= maxIndex ? 'none' : 'flex';\n    if (arrowPrev) arrowPrev.style.display = current <= 0        ? 'none' : 'flex';\n  }\n\n  // Dot clicks\n  dots.forEach(function (d) {\n    d.addEventListener('click', function () { goTo(parseInt(d.dataset.idx)); });\n  });\n\n  // Arrow clicks\n  if (arrowNext) arrowNext.addEventListener('click', function () { goTo(current + 1); });\n  if (arrowPrev) arrowPrev.addEventListener('click', function () { goTo(current - 1); });\n\n  // ── Unified pointer drag (mouse + touch) ──────────────────────────────────\n  var dragStartX  = 0;\n  var dragDelta   = 0;\n  var isDragging  = false;\n  var startOffset = 0;\n\n  function onDragStart(clientX) {\n    isDragging  = true;\n    dragStartX  = clientX;\n    dragDelta   = 0;\n    startOffset = -current * STEP;\n    list.style.transition = 'none';\n    list.style.cursor     = 'grabbing';\n  }\n  function onDragMove(clientX) {\n    if (!isDragging) return;\n    dragDelta = clientX - dragStartX;\n    var maxOffset = -maxIndex * STEP;\n    var clamped   = Math.min(0, Math.max(maxOffset, startOffset + dragDelta));\n    list.style.transform = 'translateX(' + clamped + 'px)';\n  }\n  function onDragEnd() {\n    if (!isDragging) return;\n    isDragging = false;\n    list.style.cursor = 'grab';\n    goTo(Math.abs(dragDelta) > 50 ? current + (dragDelta < 0 ? 1 : -1) : current);\n  }\n\n  // Touch\n  list.addEventListener('touchstart',  function (e) { onDragStart(e.touches[0].clientX); }, { passive: true });\n  list.addEventListener('touchmove',   function (e) { onDragMove(e.touches[0].clientX);  }, { passive: true });\n  list.addEventListener('touchend',    function ()  { onDragEnd(); },                        { passive: true });\n  list.addEventListener('touchcancel', function ()  { onDragEnd(); },                        { passive: true });\n  // Mouse\n  list.addEventListener('mousedown',   function (e) { onDragStart(e.clientX); e.preventDefault(); });\n  window.addEventListener('mousemove', function (e) { onDragMove(e.clientX); });\n  window.addEventListener('mouseup',   function ()  { onDragEnd(); });\n\n  goTo(0);\n}\n\n// Init static carousels at load time\ndocument.querySelectorAll('[data-carousel]').forEach(initCarousel);\n</script>\n\n<!-- ══════════════════════════════════ OVERLAY DETAILS ═══════════════════════════════════ -->\n<style>\n  #ov-backdrop {\n    position: fixed;\n    inset: 0;\n    background: rgba(16, 42, 67, 0.9);\n    z-index: 40;\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity 0.3s ease;\n  }\n  #ov-backdrop.is-open { opacity: 1; pointer-events: auto; }\n  #ov-panel {\n    position: fixed;\n    left: 15px;\n    right: 15px;\n    bottom: 0;\n    max-height: 90vh;\n    overflow-y: auto;\n    background: white;\n    border-radius: 8px 8px 0 0;\n    box-shadow: 0px 4px 4px 0px rgba(0,0,0,0.25);\n    z-index: 5