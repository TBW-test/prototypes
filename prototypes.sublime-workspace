div>\n\n      <!-- Checkbox + legal -->\n      <div style=\"display:flex;gap:8px;align-items:flex-start;\">\n        <input type=\"checkbox\" style=\"width:16px;height:16px;flex-shrink:0;margin-top:1px;accent-color:#0066CC;border:1px solid #4d6c89;border-radius:3px;cursor:pointer;\">\n        <p style=\"font-size:12px;color:#102A43;line-height:1.33;letter-spacing:0.1px;\">Ich habe die Nutzungsbedingungen und die Datenschutzunterrichtung zur Kenntnis genommen und akzeptiere sie.</p>\n      </div>\n\n    </div>\n\n    <!-- CTA -->\n    <button id=\"preiswecker-submit\" style=\"margin-top:20px;width:100%;height:40px;background:#3c5c7b;color:white;font-size:18px;font-weight:500;font-family:inherit;border:none;border-radius:6px;cursor:pointer;\">\n      Preiswecker stellen\n    </button>\n\n  </div>\n</div>\n\n<script>\n(function () {\n  var backdrop = document.getElementById('preiswecker-backdrop');\n  var closeBtn = document.getElementById('preiswecker-close');\n\n  function openModal() {\n    requestAnimationFrame(function () {\n      requestAnimationFrame(function () {\n        backdrop.classList.add('is-open');\n      });\n    });\n  }\n\n  function closeModal() {\n    backdrop.classList.remove('is-open');\n  }\n\n  document.getElementById('preiswecker-trigger').addEventListener('click', openModal);\n  closeBtn.addEventListener('click', closeModal);\n  document.getElementById('preiswecker-submit').addEventListener('click', closeModal);\n  backdrop.addEventListener('click', function (e) {\n    if (e.target === backdrop) closeModal();\n  });\n})();\n</script>\n\n<!-- ══════════════════════════════════ VARIANT OVERLAY ═══════════════════════════════════ -->\n<style>\n  #variant-backdrop {\n    display: none;\n    position: fixed;\n    inset: 0;\n    background: rgba(16, 42, 67, 0.9);\n    z-index: 40;\n  }\n  #variant-panel {\n    position: fixed;\n    left: 15px;\n    right: 15px;\n    bottom: 0;\n    background: white;\n    border-radius: 8px 8px 0 0;\n    padding: 44px 16px 16px;\n    box-shadow: 0px 4px 4px 0px rgba(0,0,0,0.25);\n    z-index: 50;\n    transform: translateY(100%);\n    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);\n  }\n  #variant-panel.is-open { transform: translateY(0); }\n</style>\n\n<div id=\"variant-backdrop\">\n  <div id=\"variant-panel\">\n\n    <!-- Close button -->\n    <button id=\"variant-close\" style=\"position:absolute;top:16px;right:16px;width:28px;height:28px;border-radius:50%;border:1px solid #4d6c89;background:white;display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M12 4L4 12M4 4L12 12\" stroke=\"#4d6c89\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n      </svg>\n    </button>\n\n    <!-- Title -->\n    <p style=\"font-size:16px;color:#102A43;line-height:1.2;margin-bottom:8px;\">Variante</p>\n\n    <!-- Variant list -->\n    <div style=\"display:flex;flex-direction:column;gap:8px;\">\n\n      <!-- Item 1 – selected -->\n      <div style=\"display:flex;gap:8px;align-items:center;\">\n        <div style=\"width:90px;flex-shrink:0;border:2px solid #0066CC;border-radius:4px;padding:4px;display:flex;align-items:center;justify-content:center;\">\n          <img src=\"img/figma/variant-1.png\" width=\"60\" height=\"60\" style=\"object-fit:contain;\" alt=\"EP2334/10 Schwarz\">\n        </div>\n        <div style=\"flex:1;display:flex;flex-direction:column;gap:4px;\">\n          <p style=\"font-size:14px;color:#102A43;line-height:1.2;\">EP2334/10 Schwarz</p>\n          <p style=\"font-size:14px;font-weight:600;color:#102A43;line-height:1.2;\">ab 375,53 €</p>\n          <div style=\"display:flex;gap:4px;align-items:center;\">\n            <span style=\"background:#0066CC;color:white;font-size:12px;font-weight:700;padding:2px 6px;border-radius:20px;min-width:22px;text-align:center;line-height:1.4;\">12</span>\n            <span style=\"font-size:12px;color:#102A43;\">Angebote vergleichen</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- Item 2 -->\n      <div style=\"display:flex;gap:8px;align-items:center;\">\n        <div style=\"width:90px;flex-shrink:0;border:1px solid #AEBFD1;border-radius:4px;padding:4px;display:flex;align-items:center;justify-content:center;\">\n          <img src=\"img/figma/variant-2.png\" width=\"60\" height=\"60\" style=\"object-fit:contain;\" alt=\"EP2331/10 Klavierlack-Schwarz\">\n        </div>\n        <div style=\"flex:1;display:flex;flex-direction:column;gap:4px;\">\n          <p style=\"font-size:14px;color:#0066CC;line-height:1.2;\">EP2331/10 Klavierlack-Schwarz</p>\n          <p style=\"font-size:14px;font-weight:600;color:#102A43;line-height:1.2;\">ab 395,60 €</p>\n          <div style=\"display:flex;gap:4px;align-items:center;\">\n            <span style=\"background:#0066CC;color:white;font-size:12px;font-weight:700;padding:2px 6px;border-radius:20px;min-width:22px;text-align:center;line-height:1.4;\">8</span>\n            <span style=\"font-size:12px;color:#102A43;\">Angebote vergleichen</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- Item 3 -->\n      <div style=\"display:flex;gap:8px;align-items:center;\">\n        <div style=\"width:90px;flex-shrink:0;border:1px solid #AEBFD1;border-radius:4px;padding:4px;display:flex;align-items:center;justify-content:center;\">\n          <img src=\"img/figma/variant-3.png\" width=\"60\" height=\"60\" style=\"object-fit:contain;\" alt=\"EP2336/40 schwarz verchromt\">\n        </div>\n        <div style=\"flex:1;display:flex;flex-direction:column;gap:4px;\">\n          <p style=\"font-size:14px;color:#0066CC;line-height:1.2;\">EP2336/40 schwarz verchromt</p>\n          <p style=\"font-size:14px;font-weight:600;color:#102A43;line-height:1.2;\">ab 367,00 €</p>\n          <div style=\"display:flex;gap:4px;align-items:center;\">\n            <span style=\"background:#0066CC;color:white;font-size:12px;font-weight:700;padding:2px 6px;border-radius:20px;min-width:22px;text-align:center;line-height:1.4;\">4</span>\n            <span style=\"font-size:12px;color:#102A43;\">Angebote vergleichen</span>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n(function () {\n  var backdrop = document.getElementById('variant-backdrop');\n  var panel    = document.getElementById('variant-panel');\n  var closeBtn = document.getElementById('variant-close');\n\n  function openOverlay() {\n    backdrop.style.display = 'block';\n    requestAnimationFrame(function () {\n      requestAnimationFrame(function () {\n        panel.classList.add('is-open');\n      });\n    });\n  }\n\n  function closeOverlay() {\n    panel.classList.remove('is-open');\n    panel.addEventListener('transitionend', function hide() {\n      backdrop.style.display = 'none';\n      panel.removeEventListener('transitionend', hide);\n    });\n  }\n\n  document.querySelector('.variant-selector').addEventListener('click', openOverlay);\n  closeBtn.addEventListener('click', closeOverlay);\n  backdrop.addEventListener('click', function (e) {\n    if (e.target === backdrop) closeOverlay();\n  });\n})();\n</script>\n\n<!-- ══════════════════════════════════ OVERLAY ALTERNATIVE ═══════════════════════════════ -->\n<style>\n  #alt-backdrop {\n    position: fixed; inset: 0;\n    background: rgba(16, 42, 67, 0.9);\n    z-index: 60;\n    opacity: 0; pointer-events: none;\n    transition: opacity 0.3s ease;\n  }\n  #alt-backdrop.is-open { opacity: 1; pointer-events: auto; }\n  #alt-panel {\n    position: fixed; top: 0; right: 0; bottom: 0;\n    width: 88vw; max-width: 400px;\n    background: white; border-radius: 12px 0 0 12px;\n    box-shadow: -4px 0 24px rgba(0,0,0,0.18);\n    z-index: 70;\n    overflow-y: auto;\n    transform: translateX(100%);\n    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);\n  }\n  #alt-panel.is-open { transform: translateX(0); }\n</style>\n\n<div id=\"alt-backdrop\">\n  <div id=\"alt-panel\">\n\n    <!-- Sticky close -->\n    <div style=\"position:sticky;top:0;z-index:10;background:white;display:flex;justify-content:flex-end;padding:16px 16px 0;\">\n      <button id=\"alt-close\" style=\"width:28px;height:28px;border-radius:50%;border:1px solid #4d6c89;background:white;display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;flex-shrink:0;\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M12 4L4 12M4 4L12 12\" stroke=\"#4d6c89\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n      </button>\n    </div>\n\n    <div style=\"padding:16px;display:flex;flex-direction:column;gap:20px;\">\n\n      <!-- ── Current product header — filled by renderProduct() ── -->\n      <div id=\"alt-current\" style=\"display:flex;gap:0;align-items:flex-start;border:4px solid white;border-radius:8px;padding-bottom:8px;\"></div>\n\n      <!-- ── Alternative section ── -->\n      <div style=\"display:flex;flex-direction:column;gap:8px;\">\n        <p style=\"font-size:16px;color:#102A43;line-height:1.3;\">Alternative mit besserer Benutzerfreundlichkeit:</p>\n\n        <!-- Carousel wrapper — uses the shared initCarousel() engine -->\n        <div class=\"relative px-1\" data-carousel id=\"alt-carousel-wrapper\">\n          <div class=\"overflow-hidden px-[3px]\">\n            <!-- alt cards — filled by renderProduct(), then initCarousel() is called -->\n            <div id=\"alt-carousel\" class=\"carousel-list flex gap-2 select-none\" style=\"transition:transform 0.3s ease;transform:translateX(0);cursor:grab;\"></div>\n          </div>\n          <!-- Left arrow -->\n          <button class=\"carousel-arrow-prev absolute left-1 size-[44px] rounded-full items-center justify-center z-10\" style=\"top:54px;display:none;background:rgba(255,255,255,0.85);box-shadow:0px 4px 8px 0px rgba(0,0,0,0.35);\" aria-label=\"Zurück\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#102A43\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M15 18l-6-6 6-6\"/></svg>\n          </button>\n          <!-- Right arrow -->\n          <button class=\"carousel-arrow-next absolute right-1 size-[44px] rounded-full flex items-center justify-center z-10\" style=\"top:54px;background:rgba(255,255,255,0.85);box-shadow:0px 4px 8px 0px rgba(0,0,0,0.35);\" aria-label=\"Weiter\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#102A43\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 18l6-6-6-6\"/></svg>\n          </button>\n          <!-- Dots — built dynamically by initCarousel() -->\n          <div class=\"carousel-dots flex justify-center items-center gap-3 mt-3\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function () {\n  var backdrop = document.getElementById('alt-backdrop');\n  var panel    = document.getElementById('alt-panel');\n\n  function openAlt() {\n    requestAnimationFrame(function () {\n      requestAnimationFrame(function () {\n        backdrop.classList.add('is-open');\n        panel.classList.add('is-open');\n      });\n    });\n  }\n  function closeAlt() {\n    panel.classList.remove('is-open');\n    backdrop.classList.remove('is-open');\n  }\n\n  // Event delegation — alt-trigger is re-rendered by renderProduct()\n  document.addEventListener('click', function (e) {\n    if (e.target && e.target.id === 'alt-trigger') openAlt();\n  });\n  document.getElementById('alt-close').addEventListener('click', closeAlt);\n  backdrop.addEventListener('click', function (e) { if (e.target === backdrop) closeAlt(); });\n})();\n</script>\n\n<!-- ══════════════════════════════════ RENDER PRODUCT ════════════════════════════════════ -->\n<script>\n// ── Helper: build star HTML (size 17px) from a numeric rating ────────────────\nfunction buildStars17(rating, reviewCount) {\n  var full  = Math.floor(rating);\n  var half  = (rating % 1) >= 0.25 && (rating % 1) < 0.75;\n  var empty = 5 - full - (half ? 1 : 0);\n  var uid   = 'hs' + Math.random().toString(36).slice(2, 7);\n  var html  = '<div style=\"display:flex;align-items:flex-start;\">';\n  for (var i = 0; i < full; i++)\n    html += '<div style=\"width:17px;height:17px;flex-shrink:0;margin-right:-3px;\"><img src=\"img/icons/icon-star.svg\" width=\"17\" height=\"17\" alt=\"\"></div>';\n  if (half)\n    html += '<svg width=\"17\" height=\"17\" viewBox=\"0 0 18 18\" style=\"flex-shrink:0;margin-right:-3px;\">' +\n            '<defs><clipPath id=\"' + uid + '\"><rect x=\"0\" y=\"0\" width=\"9\" height=\"18\"/></clipPath></defs>' +\n            '<path d=\"M9 1.5l2.32 4.7 5.18.75-3.75 3.65.88 5.15L9 13.27l-4.63 2.48.88-5.15L1.5 6.95l5.18-.75L9 1.5z\" fill=\"#E0E0E0\"/>' +\n            '<path d=\"M9 1.5l2.32 4.7 5.18.75-3.75 3.65.88 5.15L9 13.27l-4.63 2.48.88-5.15L1.5 6.95l5.18-.75L9 1.5z\" fill=\"#EB6800\" clip-path=\"url(#' + uid + ')\"/>' +\n            '</svg>';\n  for (var j = 0; j < empty; j++)\n    html += '<div style=\"width:17px;height:17px;flex-shrink:0;margin-right:-3px;\"><img src=\"img/icons/icon-star-empty.svg\" width=\"17\" height=\"17\" alt=\"\"></div>';\n  html += '</div>';\n  if (reviewCount) html += '<span style=\"font-size:12px;color:#3c5c7b;margin-left:2px;\">(' + reviewCount + ')</span>';\n  return html;\n}\n\n// ── Helper: set text on element by id safely ─────────────────────────────────\nfunction setText(id, val) { var el = document.getElementById(id); if (el) el.textContent = val; }\nfunction setHTML(id, val) { var el = document.getElementById(id); if (el) el.innerHTML    = val; }\nfunction setAttr(id, attr, val) { var el = document.getElementById(id); if (el) el[attr] = val; }\n\nfunction renderProduct() {\n  var P = PRODUCT;\n\n  // ── Hero ──────────────────────────────────────────────────────────────────\n  setAttr('hero-img',      'src', P.heroImage);\n  setAttr('hero-img',      'alt', P.name);\n  setAttr('hero-shop-logo','src', P.bestPriceShop.logo);\n  setAttr('hero-shop-logo','alt', P.bestPriceShop.alt);\n  setText('hero-price',    P.bestPrice);\n  setText('hero-shipping', P.bestPriceShop.shipping);\n  setText('hero-discount', P.discount);\n  setText('hero-name',     P.name);\n  setText('hero-attributes', P.attributes);\n  setText('hero-variant',  P.variant);\n  setText('hero-cta-btn',  P.offerListCount + ' Angebote ab ' + P.bestPrice + ' €');\n\n  // ── Unsere Bewertung ──────────────────────────────────────────────────────\n  setText('bew-rating',  P.rating.toFixed(1).replace('.', ','));\n  setText('bew-summary', P.reviewSummary);\n\n  var prosConsHtml = '';\n  P.pros.forEach(function (pro) {\n    prosConsHtml += '<div class=\"flex items-start gap-2 pl-1\">' +\n      '<div class=\"shrink-0 pt-0.5 w-4\"><img src=\"img/icons/icon-plus-circle.svg\" width=\"18\" height=\"18\" alt=\"\"></div>' +\n      '<span class=\"text-sm text-ink leading-[1.5]\">' + pro + '</span></div>';\n  });\n  P.cons.forEach(function (con) {\n    prosConsHtml += '<div class=\"flex items-start gap-2 pl-1\">' +\n      '<div class=\"shrink-0 pt-0.5 w-4\"><img src=\"img/icons/icon-minus-circle-orange.svg\" width=\"18\" height=\"18\" alt=\"\"></div>' +\n      '<span class=\"text-sm text-ink leading-[1.5]\">' + con + '</span></div>';\n  });\n  var logoCircles = P.sourceLogos.map(function (logo) {\n    return '<div class=\"w-[18px] h-[18px] rounded-full border border-stroke overflow-hidden -mr-2 shrink-0 bg-white\">' +\n           '<img src=\"' + logo + '\" width=\"18\" height=\"18\" class=\"object-cover w-full h-full\" alt=\"\"></div>';\n  }).join('');\n  prosConsHtml += '<div class=\"flex items-center gap-1 pl-1\">' +\n    '<div class=\"flex items-center pr-2 shrink-0\">' + logoCircles + '</div>' +\n    '<span class=\"text-sm text-ink-weak leading-[1.5]\">Ergebnis aus ' + P.sources.length + ' Quellen</span></div>';\n  setHTML('bew-proscons', prosConsHtml);\n\n  // ── Preisvergleich ────────────────────────────────────────────────────────\n  setText('price-range-text', P.priceRange);\n\n  var offerHtml = '';\n  P.offers.forEach(function (o, i) {\n    offerHtml += '<div class=\"offer-item border-t border-stroke p-2\">' +\n      '<div class=\"flex gap-[10px] items-start\">' +\n        '<div class=\"flex flex-col gap-1.5 flex-1 min-w-0\">' +\n          '<div class=\"h-9 w-[88px]\"><img src=\"' + o.shopLogo + '\" class=\"w-full max-h-[25px] object-contain object-left\" alt=\"' + o.shopAlt + '\"></div>' +\n          '<div class=\"flex gap-2 items-start\">' +\n            '<div class=\"w-[40px] shrink-0 flex items-center justify-center\"><img src=\"' + o.thumb + '\" class=\"max-w-full max-h-[40px] object-contain\" alt=\"\"></div>' +\n            '<div class=\"flex flex-col gap-2 justify-between self-stretch flex-1 min-w-0\">' +\n              '<p class=\"text-[12px] font-semibold text-link leading-[1.3]\">' + o.title + '</p>' +\n              '<div class=\"flex items-center gap-1\" data-offer=\"' + i + '\" style=\"cursor:pointer;\">' +\n                '<img src=\"img/icons/icon-info-link.svg\" width=\"16\" height=\"16\" alt=\"\">' +\n                '<span class=\"text-[12px] text-link underline\">Details</span>' +\n              '</div>' +\n            '</div>' +\n          '</div>' +\n        '</div>' +\n        '<div class=\"flex flex-col items-end w-[100px] shrink-0 self-stretch text-right\">' +\n          '<span class=\"text-[20px] font-semibold text-ink leading-[1.2] whitespace-nowrap\">' + o.price + ' €</span>' +\n          '<span class=\"text-[11px] font-medium text-ink-weak leading-[1.4] whitespace-nowrap\">' + o.shipping + '</span>' +\n          '<div class=\"mt-auto flex items-start gap-1 text-[12px] text-ink\">' +\n            '<img src=\"' + o.truckIcon + '\" width=\"16\" height=\"16\" class=\"shrink-0 mt-px\" alt=\"\">' +\n            '<span class=\"text-left lead