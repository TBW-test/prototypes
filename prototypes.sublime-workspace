<path d=\"M15 15l3.5 3.5\" stroke=\"#102A43\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n              </svg>\n            </div>\n          </div>\n        </div>\n\n        <!-- Product title -->\n        <p id=\"ov-name\" style=\"font-family:'DM Sans',system-ui,sans-serif;font-size:16px;color:#102A43;line-height:1.2;\">PHILIPS EP2331/10 LatteGo</p>\n      </div>\n\n      <!-- ── Summary card ── -->\n      <div style=\"background:#f5f7fa;border-radius:6px;padding:12px;display:flex;flex-direction:column;gap:6px;\">\n        <!-- Rating -->\n        <div style=\"display:flex;align-items:center;gap:4px;\">\n          <span id=\"ov-rating-num\" style=\"font-size:16px;font-weight:700;color:#102A43;\">4,5</span>\n          <div style=\"display:flex;align-items:flex-start;padding-right:3px;\">\n            <div style=\"width:24px;height:24px;flex-shrink:0;margin-right:-3px;\"><img src=\"img/icons/icon-star.svg\" width=\"24\" height=\"24\" alt=\"\"></div>\n            <div style=\"width:24px;height:24px;flex-shrink:0;margin-right:-3px;\"><img src=\"img/icons/icon-star.svg\" width=\"24\" height=\"24\" alt=\"\"></div>\n            <div style=\"width:24px;height:24px;flex-shrink:0;margin-right:-3px;\"><img src=\"img/icons/icon-star.svg\" width=\"24\" height=\"24\" alt=\"\"></div>\n            <div style=\"width:24px;height:24px;flex-shrink:0;margin-right:-3px;\"><img src=\"img/icons/icon-star.svg\" width=\"24\" height=\"24\" alt=\"\"></div>\n            <div style=\"flex-shrink:0;margin-right:-3px;\">\n              <svg width=\"24\" height=\"24\" viewBox=\"0 0 18 18\">\n                <defs><clipPath id=\"half-ov\"><rect x=\"0\" y=\"0\" width=\"9\" height=\"18\"/></clipPath></defs>\n                <path d=\"M9 1.5l2.32 4.7 5.18.75-3.75 3.65.88 5.15L9 13.27l-4.63 2.48.88-5.15L1.5 6.95l5.18-.75L9 1.5z\" fill=\"#E0E0E0\" stroke=\"#854913\" stroke-width=\"0.5\" stroke-linejoin=\"round\"/>\n                <path d=\"M9 1.5l2.32 4.7 5.18.75-3.75 3.65.88 5.15L9 13.27l-4.63 2.48.88-5.15L1.5 6.95l5.18-.75L9 1.5z\" fill=\"#FFA41C\" clip-path=\"url(#half-ov)\"/>\n              </svg>\n            </div>\n          </div>\n        </div>\n        <!-- Review text -->\n        <p id=\"ov-summary\" style=\"font-size:14px;color:#102A43;line-height:1.2;\">Vielseitiger Kaffeezauber. Breite Getränkeauswahl, individuelle Einstellungen, intuitive Bedienung und hoher Komfort – dieses Modell punktet in allen Bereichen und erreicht im Test einen beeindruckenden zweiten Platz.</p>\n        <!-- Source logos — filled by renderProduct() -->\n        <div id=\"ov-source-logos\" style=\"display:flex;align-items:center;gap:4px;padding-left:4px;\"></div>\n      </div>\n\n      <!-- ── Auswertung ── -->\n      <div style=\"display:flex;flex-direction:column;gap:10px;\">\n        <p style=\"font-family:'DM Sans',system-ui,sans-serif;font-size:20px;color:#102A43;line-height:1.2;\">Auswertung</p>\n        <!-- scores — filled by renderProduct() -->\n        <div id=\"ov-scores\" style=\"display:flex;flex-direction:column;gap:10px;\"></div>\n        <button id=\"ov-datenblatt-btn\" style=\"width:100%;height:40px;background:#f5f7fa;border:1px solid #67829d;border-radius:6px;font-size:14px;font-weight:500;font-family:inherit;color:#102A43;cursor:pointer;\">Datablatt ansehen</button>\n      </div>\n\n      <!-- ── FAQ ── -->\n      <div style=\"display:flex;flex-direction:column;gap:10px;\">\n        <p style=\"font-family:'DM Sans',system-ui,sans-serif;font-size:20px;color:#102A43;line-height:1.2;\">Frage zum Produkt</p>\n        <!-- faq items — filled by renderProduct() -->\n        <div id=\"ov-faq\"></div>\n      </div>\n\n      <!-- ── Quellen ── -->\n      <div id=\"ov-quellen\" style=\"display:flex;flex-direction:column;gap:10px;\">\n        <p style=\"font-family:'DM Sans',system-ui,sans-serif;font-size:20px;color:#102A43;line-height:1.2;\">Quelle</p>\n        <!-- quellen cards — filled by renderProduct() -->\n        <div id=\"ov-quellen-list\" style=\"display:flex;flex-direction:column;gap:10px;\"></div>\n      </div>\n    </div><!-- /content -->\n  </div><!-- /panel -->\n</div><!-- /backdrop -->\n\n<script>\n(function () {\n  var backdrop = document.getElementById('ov-backdrop');\n  var panel    = document.getElementById('ov-panel');\n\n  function openOv() {\n    panel.scrollTop = 0;\n    requestAnimationFrame(function () {\n      requestAnimationFrame(function () {\n        backdrop.classList.add('is-open');\n        panel.classList.add('is-open');\n      });\n    });\n  }\n\n  function closeOv() {\n    panel.classList.remove('is-open');\n    backdrop.classList.remove('is-open');\n  }\n\n  document.getElementById('ov-open-btn').addEventListener('click', openOv);\n  document.getElementById('ov-close').addEventListener('click', closeOv);\n  backdrop.addEventListener('click', function (e) {\n    if (e.target === backdrop) closeOv();\n  });\n  // Event delegation for quellen-link (re-rendered by renderProduct)\n  document.addEventListener('click', function (e) {\n    if (e.target && e.target.id === 'ov-quellen-link') {\n      var panel2     = document.getElementById('ov-panel');\n      var target2    = document.getElementById('ov-quellen');\n      var stickyBar  = panel2.querySelector('[style*=\"position:sticky\"]');\n      var stickyH    = stickyBar ? stickyBar.offsetHeight : 0;\n      panel2.scrollTo({ top: target2.offsetTop - stickyH - 8, behavior: 'smooth' });\n    }\n  });\n\n  document.getElementById('ov-datenblatt-btn').addEventListener('click', function () {\n    closeOv();\n    setTimeout(function () {\n      document.getElementById('datenblatt').scrollIntoView({ behavior: 'smooth' });\n    }, 350);\n  });\n\n  // Image slider\n  var mainImg   = document.getElementById('ov-main-img');\n  var thumbList = document.getElementById('ov-thumb-list');\n  var thumbUp   = document.getElementById('ov-thumb-up');\n  var thumbDown = document.getElementById('ov-thumb-down');\n\n  // Event delegation for thumbs (re-rendered by renderProduct)\n  thumbList.addEventListener('click', function (e) {\n    var thumb = e.target.closest('.ov-thumb');\n    if (!thumb) return;\n    document.querySelectorAll('#ov-panel .ov-thumb').forEach(function (t) { t.classList.remove('active'); });\n    thumb.classList.add('active');\n    mainImg.src = thumb.getAttribute('data-img');\n  });\n\n  function updateThumbArrows() {\n    var st  = thumbList.scrollTop;\n    var max = thumbList.scrollHeight - thumbList.clientHeight;\n    thumbUp.style.visibility   = st > 4       ? 'visible' : 'hidden';\n    thumbDown.style.visibility = st < max - 4 ? 'visible' : 'hidden';\n  }\n\n  thumbList.addEventListener('scroll', updateThumbArrows);\n  // Re-check once images have loaded so scroll metrics are accurate\n  window.addEventListener('load', updateThumbArrows);\n\n  // 48px = 40px thumb + 8px gap\n  thumbUp.addEventListener('click',   function () { thumbList.scrollBy({ top: -48, behavior: 'smooth' }); });\n  thumbDown.addEventListener('click', function () { thumbList.scrollBy({ top:  48, behavior: 'smooth' }); });\n\n  // FAQ accordion — event delegation so it works after renderProduct() re-renders\n  document.getElementById('ov-faq').addEventListener('click', function (e) {\n    var trigger = e.target.closest('.ov-faq-trigger');\n    if (!trigger) return;\n    var item   = trigger.closest('.ov-faq-item');\n    var isOpen = item.classList.contains('open');\n    document.querySelectorAll('#ov-faq .ov-faq-item').forEach(function (i) { i.classList.remove('open'); });\n    if (!isOpen) item.classList.add('open');\n  });\n})();\n</script>\n\n<!-- ══════════════════════════════════ ZOOM OVERLAY ═════════════════════════════════════ -->\n<style>\n  #zoom-backdrop {\n    position: fixed; inset: 0;\n    background: rgba(16,42,67,0.9);\n    z-index: 80;\n    display: flex; align-items: center; justify-content: center;\n    opacity: 0; pointer-events: none;\n    transition: opacity 0.3s ease;\n  }\n  #zoom-backdrop.is-open { opacity: 1; pointer-events: auto; }\n  #zoom-panel {\n    background: white;\n    border-radius: 8px;\n    box-shadow: 0 4px 24px rgba(0,0,0,0.25);\n    width: calc(100vw - 30px);\n    max-width: 460px;\n    padding: 44px 16px 16px;\n    position: relative;\n    display: flex; flex-direction: column; gap: 12px;\n    opacity: 0;\n    transform: scale(0.95);\n    transition: opacity 0.3s ease, transform 0.35s cubic-bezier(0.34,1.56,0.64,1);\n  }\n  #zoom-backdrop.is-open #zoom-panel { opacity: 1; transform: scale(1); }\n  .zoom-thumb { border:1px solid #aebfd1; border-radius:4px; padding:4px; box-sizing:border-box; width:40px; height:40px; display:flex; align-items:center; justify-content:center; cursor:pointer; background:white; flex-shrink:0; }\n  .zoom-thumb.active { border:2px solid #3c5c7b; }\n  #zoom-thumb-list { display:flex; flex-direction:row; gap:8px; overflow-x:auto; scrollbar-width:none; }\n  #zoom-thumb-list::-webkit-scrollbar { display:none; }\n</style>\n\n<div id=\"zoom-backdrop\">\n  <div id=\"zoom-panel\">\n\n    <!-- Close button -->\n    <button id=\"zoom-close\" style=\"position:absolute;top:16px;right:16px;width:28px;height:28px;border-radius:50%;border:1px solid #4d6c89;background:white;display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M12 4L4 12M4 4L12 12\" stroke=\"#4d6c89\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n    </button>\n\n    <!-- Swipeable main image -->\n    <div style=\"position:relative;height:300px;overflow:hidden;border-radius:4px;\">\n      <!-- zoom slides — filled by renderProduct() -->\n      <div id=\"zoom-track\" style=\"display:flex;height:100%;transition:transform 0.3s ease;will-change:transform;\"></div>\n      <!-- Prev arrow -->\n      <button id=\"zoom-prev\" style=\"position:absolute;left:4px;top:50%;transform:translateY(-50%);width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.85);border:none;box-shadow:0 2px 8px rgba(0,0,0,0.2);display:none;align-items:center;justify-content:center;cursor:pointer;padding:0;z-index:2;\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M10 4l-4 4 4 4\" stroke=\"#102A43\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n      </button>\n      <!-- Next arrow -->\n      <button id=\"zoom-next\" style=\"position:absolute;right:4px;top:50%;transform:translateY(-50%);width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.85);border:none;box-shadow:0 2px 8px rgba(0,0,0,0.2);display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;z-index:2;\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M6 4l4 4-4 4\" stroke=\"#102A43\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n      </button>\n    </div>\n\n    <!-- Horizontal thumbnail strip — filled by renderProduct() -->\n    <div id=\"zoom-thumb-list\"></div>\n\n  </div>\n</div>\n\n<script>\n(function () {\n  var backdrop   = document.getElementById('zoom-backdrop');\n  var track      = document.getElementById('zoom-track');\n  var prevBtn    = document.getElementById('zoom-prev');\n  var nextBtn    = document.getElementById('zoom-next');\n  var zThumbList = document.getElementById('zoom-thumb-list');\n  var zThumbs    = document.querySelectorAll('#zoom-thumb-list .zoom-thumb');\n\n  var zoomImages = PRODUCT.images.map(function (img) { return img.src; });\n  var zoomIndex = 0;\n\n  function goTo(index) {\n    zoomImages = PRODUCT.images.map(function (img) { return img.src; }); // re-sync in case PRODUCT changed\n    zoomIndex = Math.max(0, Math.min(index, zoomImages.length - 1));\n    track.style.transform = 'translateX(-' + (zoomIndex * 100) + '%)';\n\n    // Prev / Next arrows\n    prevBtn.style.display = zoomIndex > 0                      ? 'flex' : 'none';\n    nextBtn.style.display = zoomIndex < zoomImages.length - 1 ? 'flex' : 'none';\n\n    // Thumbnail active state + scroll into view (48px = 40px + 8px gap)\n    document.querySelectorAll('#zoom-thumb-list .zoom-thumb').forEach(function (t, i) {\n      t.classList.toggle('active', i === zoomIndex);\n    });\n    zThumbList.scrollTo({ left: zoomIndex * 48 - 16, behavior: 'smooth' });\n\n    // Sync back to ov-panel\n    var ovMainImg = document.getElementById('ov-main-img');\n    if (ovMainImg) ovMainImg.src = zoomImages[zoomIndex];\n    document.querySelectorAll('#ov-thumb-list .ov-thumb').forEach(function (t, i) {\n      t.classList.toggle('active', i === zoomIndex);\n    });\n  }\n\n  // Thumbnail clicks — event delegation so it works after renderProduct() re-renders\n  zThumbList.addEventListener('click', function (e) {\n    var thumb = e.target.closest('.zoom-thumb');\n    if (thumb) goTo(parseInt(thumb.getAttribute('data-index')));\n  });\n\n  // Prev / Next\n  prevBtn.addEventListener('click', function () { goTo(zoomIndex - 1); });\n  nextBtn.addEventListener('click', function () { goTo(zoomIndex + 1); });\n\n  // Touch swipe on main image\n  var touchStartX = 0;\n  track.addEventListener('touchstart', function (e) { touchStartX = e.touches[0].clientX; }, { passive: true });\n  track.addEventListener('touchend',   function (e) {\n    var dx = e.changedTouches[0].clientX - touchStartX;\n    if (Math.abs(dx) > 40) goTo(zoomIndex + (dx < 0 ? 1 : -1));\n  });\n\n  // Open — starts at current ov-panel image\n  function openZoom() {\n    var ovMainImg = document.getElementById('ov-main-img');\n    var startIdx  = 0;\n    if (ovMainImg) {\n      var src = ovMainImg.src.split('?')[0];\n      var found = zoomImages.indexOf(src);\n      if (found >= 0) startIdx = found;\n    }\n    track.style.transition = 'none';\n    goTo(startIdx);\n    requestAnimationFrame(function () {\n      requestAnimationFrame(function () {\n        track.style.transition = 'transform 0.3s ease';\n        backdrop.classList.add('is-open');\n      });\n    });\n  }\n\n  function closeZoom() { backdrop.classList.remove('is-open'); }\n\n  document.getElementById('zoom-close').addEventListener('click', closeZoom);\n  backdrop.addEventListener('click', function (e) { if (e.target === backdrop) closeZoom(); });\n\n  document.getElementById('ov-main-img').addEventListener('click', openZoom);\n  document.getElementById('ov-main-img').style.cursor = 'zoom-in';\n})();\n</script>\n\n<!-- ══════════════════════════════════ OFFER DETAILS OVERLAY ════════════════════════════ -->\n<style>\n  #offer-details-backdrop {\n    position: fixed;\n    inset: 0;\n    background: rgba(16, 42, 67, 0.9);\n    z-index: 40;\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity 0.3s ease;\n  }\n  #offer-details-backdrop.is-open {\n    opacity: 1;\n    pointer-events: auto;\n  }\n  #offer-details-panel {\n    position: fixed;\n    left: 15px;\n    right: 15px;\n    bottom: 0;\n    background: white;\n    border-radius: 8px 8px 0 0;\n    padding: 16px;\n    box-shadow: 0px 4px 4px 0px rgba(0,0,0,0.25);\n    z-index: 50;\n    transform: translateY(100%);\n    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);\n  }\n  #offer-details-panel.is-open { transform: translateY(0); }\n  #offer-details-desc { max-height: 180px; overflow-y: auto; padding-right: 8px; }\n</style>\n\n<div id=\"offer-details-backdrop\">\n  <div id=\"offer-details-panel\">\n\n    <!-- Close -->\n    <div style=\"display:flex;justify-content:flex-end;margin-bottom:16px;\">\n      <button id=\"offer-details-close\" style=\"width:44px;height:44px;border-radius:50%;background:#f5f7fa;border:none;display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0;flex-shrink:0;\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M12 4L4 12M4 4L12 12\" stroke=\"#4d6c89\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n      </button>\n    </div>\n\n    <!-- Title -->\n    <p id=\"od-title\" style=\"font-family:'DM Sans',system-ui,sans-serif;font-size:20px;color:#102A43;line-height:1.2;margin-bottom:16px;\"></p>\n\n    <!-- Description -->\n    <div id=\"offer-details-desc\" style=\"margin-bottom:16px;\">\n      <p id=\"od-desc\" style=\"font-size:12px;color:#3c5c7b;line-height:1.4;\"></p>\n    </div>\n\n    <!-- Footer: thumb + logo + price -->\n    <div style=\"display:flex;gap:16px;align-items:center;margin-bottom:16px;\">\n      <div style=\"width:50px;height:50px;flex-shrink:0;\">\n        <img id=\"od-thumb\" src=\"\" width=\"50\" height=\"50\" style=\"width:100%;height:100%;object-fit:contain;\" alt=\"\">\n      </div>\n      <div style=\"flex:1;min-width:0;\">\n        <img id=\"od-logo\" src=\"\" style=\"height:36px;width:88px;object-fit:contain;object-position:left;\" alt=\"\">\n      </div>\n      <div style=\"display:flex;flex-direction:column;align-items:flex-end;text-align:right;flex-shrink:0;\">\n        <div style=\"display:flex;gap:3px;align-items:baseline;\">\n          <span id=\"od-price\" style=\"font-size:20px;font-weight:600;color:#102A43;line-height:1.2;\"></span>\n          <span style=\"font-size:20px;font-weight:500;color:#102A43;line-height:1.2;\">€</span>\n        </div>\n        <span id=\"od-shipping\" style=\"font-size:11px;font-weight:500;color:#3c5c7b;line-height:1.4;white-space:nowrap;\"></span>\n        <div style=\"display:flex;gap:4px;align-items:flex-start;margin-top:4px;\">\n          <img id=\"od-truck\" src=\"\" width=\"16\" height=\"16\" style=\"flex-shrink:0;margin-top:1px;\" alt=\"\">\n          <span id=\"od-delivery\" style=\"font-size:12px;color:#102A43;line-height:1.3;text-align:left;\"></span>\n        </div>\n      </div>\n    </div>\n\n    <!-- CTA -->\n    <button id=\"offer-details-shop\" style=\"width:100%;max-width:308px;height:40px;background:#3c5c7b;color:white;font-size:14px;font-weight:500;font-family:inherit;border:none;border-radius:6px;cursor:pointer;display:block;margin:0 auto;\">zum Shop</button>\n\n  </div>\n</div>\n\n<script>\n(function () {\n  // Map from PRODUCT.offers to the format expected by this overlay\n  var offers = PRODUCT.offers.map(function (o) {\n    return {\n      title: o.title, desc: o.desc,\n      thumb: o.thumb, logo: o.shopLogo, logoAlt: o.shopAlt,\n      price: o.price, shipping: o.shipping,\n      truck: o.truckIcon, delivery: o.delivery\n    };\n  });\n\n  // Wire up Details links via data attribute\n  document.querySelectorAll('.offer-item').forEach(function (item, i) {\n    var detailsRow = item.querySelector('.flex.items-center.gap-1');\n    if (detailsRow) {\n      detailsRow.setAttribute('data-offer', i);\n      detailsRow.style.cursor = 'pointer';\n    }\n  });\n\n  var backdrop = document.getElementById('offer-details-backdrop');\n  var panel    = document.getElementById('offer-details-panel');\n\n  function openOfferDetails(index) {\n    var o = offers[index];\n    document.getElementById('od-title').textContent    = o.title;\n    document.getElementById('od-desc').textContent     = o.desc;\n    document.getElementById('od-thumb').src            = o.thumb;\n    document.getElementById('od-logo').src             = o.logo;\n    document.getElementById('od-logo').alt             = o.logoAlt;\n    document.getElementById('od-price').textContent    = o.price;\n    document.getElementById('od-shipping').textContent = o.shipping;\n    document.getElementById('od-truck').src            = o.truck;\n    document.getElementById('od-delivery').textContent = o.delivery;\n    requestAnimationFrame(function () {\n      requestAnimationFrame(function () {\n        backdrop.classList.add('is-open');\n        panel.classList.add('is-open');\n      });\n    });\n  }\n\n  function closeOfferDetails() {\n    backdrop.classList.remove('is-open');\n    panel.classList.remove('is-open');\n  }\n\n  document.addEventListener('click', function (e) {\n    var trigger = e.target.closest('[data-offer]');\n    if (trigger && backdrop.contains(trigger) === false) {\n      openOfferDetails(parseInt(trigger.getAttribute('data-offer')));\n    }\n  });\n\n  document.getElementById('offer-details-close').addEventListener('click', closeOfferDetails);\n  document.getElementById('offer-details-shop').addEventListener('click', closeOfferDetails);\n  backdrop.addEventListener('click', function (e) {\n    if (e.target === backdrop) closeOfferDetails();\n  });\n})();\n</script>\n\n<!-- ══════════════════════════════════ PREISWECKER MODAL ═════════════════════════════════ -->\n<style>\n  #preiswecker-backdrop {\n    display: flex;\n    position: fixed;\n    inset: 0;\n    background: rgba(16, 42, 67, 0.9);\n    z-index: 40;\n    align-items: center;\n    justify-content: center;\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity 0.3s ease;\n  }\n  #preiswecker-backdrop.is-open {\n    opacity: 1;\n    pointer-events: auto;\n  }\n  #preiswecker-modal {\n    background: white;\n    border-radius: 8px;\n    padding: 44px 16px 16px;\n    box-shadow: 0px 4px 4px 0px rgba(0,0,0,0.25);\n    width: calc(100% - 30px);\n    max-width: 470px;\n    position: relative;\n    opacity: 0;\n    transform: scale(0.92) translateY(12px);\n    transition: opacity 0.3s ease, transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);\n  }\n  #preiswecker-backdrop.is-open #preiswecker-modal {\n    opacity: 1;\n    transform: scale(1) translateY(0);\n  }\n  #preiswecker-modal input[type=\"text\"],\n  #preiswecker-modal input[type=\"email\"] {\n    width: 100%;\n    height: 40px;\n    border: 1px solid #4d6c89;\n    border-radius: 6px;\n    padding: 0 15px;\n    font-size: 16px;\n    font-family: inherit;\n    color: #102A43;\n    background: white;\n    box-sizing: border-box;\n    outline: none;\n  }\n  #preiswecker-modal input[type=\"text\"]:focus,\n  #preiswecker-modal input[type=\"email\"]:focus {\n    border-color: #0066CC;\n    box-shadow: 0 0 0 2px rgba(0,102,204,0.15);\n  }\n</style>\n\n<div id=