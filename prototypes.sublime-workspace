"0.02\"/>\n            </linearGradient>\n          </defs>\n          <!-- Dashed grid lines — generated by JS from priceChartYLabels via toY() -->\n          <g id=\"pe-grid\"></g>\n          <!-- Paths filled by JS -->\n          <path id=\"pe-area\" d=\"\" fill=\"url(#pe-grad)\"/>\n          <path id=\"pe-line\" d=\"\" fill=\"none\" stroke=\"#0066CC\" stroke-width=\"1.5\" stroke-linejoin=\"round\" stroke-linecap=\"round\"/>\n          <!-- Interactive indicator (hidden initially) -->\n          <line id=\"pe-vline\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"145\" stroke=\"#67829D\" stroke-width=\"1\" stroke-dasharray=\"3,2\" display=\"none\"/>\n          <circle id=\"pe-dot\" cx=\"0\" cy=\"0\" r=\"3.5\" fill=\"white\" stroke=\"#0066CC\" stroke-width=\"2\" display=\"none\"/>\n        </svg>\n        <!-- Price tooltip -->\n        <div id=\"pe-tooltip\"\n             style=\"display:none;position:absolute;transform:translateX(-50%);pointer-events:none;z-index:10;\">\n          <div style=\"background:#102A43;color:#fff;font-size:11px;font-weight:600;padding:3px 7px;border-radius:5px;white-space:nowrap;box-shadow:0 1px 4px rgba(0,0,0,.2);\">\n            <span id=\"pe-price\"></span>\n          </div>\n        </div>\n        <!-- Invisible mouse/touch overlay -->\n        <div id=\"pe-overlay\" style=\"position:absolute;inset:0;cursor:crosshair;touch-action:none;\"></div>\n      </div>\n    </div>\n  </div>\n\n  <!-- X-axis labels — outside the card, aligned with the SVG left/right edges.\n       padding-left = px-2 (8px) + y-label width (30px) + gap-1 (4px) = 42px\n       padding-right = px-2 (8px) -->\n  <div class=\"flex justify-between mb-3.5\" style=\"padding-left:42px;padding-right:8px;\">\n    <span class=\"text-[12px] text-ink-weak pe-x-label\">01.03</span>\n    <span class=\"text-[12px] text-ink-weak pe-x-label\">01.04</span>\n    <span class=\"text-[12px] text-ink-weak pe-x-label\">01.05</span>\n  </div>\n\n  <!-- Info box -->\n  <div class=\"flex items-center gap-2 rounded-[6px] px-2 py-1 mb-3\" style=\"background:linear-gradient(90deg,rgba(0,102,204,.1),rgba(0,102,204,.1)),white;\">\n    <div id=\"pe-discount\" class=\"shrink-0 bg-link text-white text-base font-medium px-1 py-1 rounded-[4px] whitespace-nowrap leading-none\">-25%</div>\n    <p id=\"pe-savings\" class=\"text-sm text-ink leading-[1.4]\">\n      Der Preis liegt derzeit 25% unter dem Durchschnitt der letzten 60 Tage. Das sind <strong class=\"font-bold\">53,71€ Ersparnis für Sie!</strong>\n    </p>\n  </div>\n\n  <button class=\"flex items-center justify-center w-full h-10 bg-surface-100 text-ink text-sm font-medium border border-ink-muted rounded-[6px] cursor-pointer\" onclick=\"document.querySelector('.price-comparaison').scrollIntoView({behavior:'smooth'})\">Alle Angebote ansehen</button>\n</section>\n\n<script>\n(function () {\n  // 90-day price series from PRODUCT data\n  var P   = PRODUCT.priceData;\n  var MIN = PRODUCT.priceChartMin, MAX = PRODUCT.priceChartMax, W = 300, H = 145;\n  // H      = SVG viewBox height (145) — never changes\n  // H_CHART = usable plotting height — leaves 12 px of breathing room below the last label\n  var H_CHART = H - 12;\n\n  function toX(i)  { return (i / (P.length - 1)) * W; }\n  function toY(p)  { return ((MAX - p) / (MAX - MIN)) * H_CHART; }\n\n  // Build path strings\n  var pts = P.map(function(p, i) { return toX(i).toFixed(1) + ',' + toY(p).toFixed(1); });\n  var linePath = 'M' + pts.join('L');\n  // Area fill closes at H (full SVG bottom) so the gradient reaches the edge\n  var areaPath = linePath + 'L' + toX(P.length - 1).toFixed(1) + ',' + H + 'L0,' + H + 'Z';\n\n  // Apply curve paths\n  var areaEl = document.getElementById('pe-area');\n  var lineEl = document.getElementById('pe-line');\n  if (areaEl) areaEl.setAttribute('d', areaPath);\n  if (lineEl) lineEl.setAttribute('d', linePath);\n\n  // Generate grid lines from the same priceChartYLabels data used for Y-axis labels,\n  // so every line falls exactly on the SVG y-coordinate that toY() produces.\n  var gridEl = document.getElementById('pe-grid');\n  if (gridEl) {\n    var labelPrices = PRODUCT.priceChartYLabels.map(function (l) {\n      return parseFloat(l.replace(/[^0-9.]/g, ''));\n    });\n    gridEl.innerHTML = labelPrices.map(function (price) {\n      var y = toY(price).toFixed(1);\n      return '<line x1=\"0\" y1=\"' + y + '\" x2=\"300\" y2=\"' + y +\n             '\" stroke=\"#E4EAF1\" stroke-width=\"1\" stroke-dasharray=\"4,3\"/>';\n    }).join('');\n  }\n\n  // Interaction\n  var overlay  = document.getElementById('pe-overlay');\n  var svg      = document.getElementById('pe-svg');\n  var vline    = document.getElementById('pe-vline');\n  var dot      = document.getElementById('pe-dot');\n  var tooltip  = document.getElementById('pe-tooltip');\n  var priceEl  = document.getElementById('pe-price');\n\n  if (!overlay || !svg || !vline || !dot || !tooltip || !priceEl) return;\n\n  function show(clientX) {\n    var oRect   = overlay.getBoundingClientRect();\n    var svgRect = svg.getBoundingClientRect();\n    var xFrac   = Math.min(Math.max((clientX - oRect.left) / oRect.width, 0), 1);\n    var idx     = Math.round(xFrac * (P.length - 1));\n    var price   = P[idx];\n    var svgX    = toX(idx);\n    var svgY    = toY(price);\n\n    // SVG viewBox → rendered pixel coordinates\n    var pixX = (svgX / W) * svgRect.width;\n    var pixY = (svgY / H) * svgRect.height;\n\n    vline.setAttribute('x1', svgX);\n    vline.setAttribute('x2', svgX);\n    vline.removeAttribute('display');\n\n    dot.setAttribute('cx', svgX);\n    dot.setAttribute('cy', svgY);\n    dot.removeAttribute('display');\n\n    // Tooltip: positioned below the dot on the line\n    tooltip.style.display = 'block';\n    tooltip.style.left    = pixX + 'px';\n    tooltip.style.top     = (pixY + 9) + 'px';\n    priceEl.textContent   = price.toLocaleString('de-DE') + ' €';\n  }\n\n  function hide() {\n    vline.setAttribute('display', 'none');\n    dot.setAttribute('display', 'none');\n    tooltip.style.display = 'none';\n  }\n\n  overlay.addEventListener('mousemove',  function(e) { show(e.clientX); });\n  overlay.addEventListener('mouseleave', hide);\n  overlay.addEventListener('touchmove',  function(e) {\n    e.preventDefault();\n    if (e.touches.length) show(e.touches[0].clientX);\n  }, { passive: false });\n  overlay.addEventListener('touchend', hide);\n})();\n</script>\n\n<div class=\"h-2></div>\n\n<!-- ═══════════════════════════════════════ ÄHNLICH GUT ═════════════════════════════════ -->\n<section class=\"bg-white pt-4 pb-3\">\n  <div class=\"px-3 mb-3\">\n    <div class=\"font-display text-[20px] font-normal leading-[1.2] text-ink\">Ähnlich gut</div>\n  </div>\n  <div class=\"relative px-1\" data-carousel>\n    <div class=\"overflow-hidden px-[3px]\">\n      <div class=\"carousel-list flex gap-2 select-none\" style=\"transition: transform 0.3s ease; transform: translateX(0); cursor: grab;\">\n\n        <!-- Card 1 — Midea MKE17M1ADS -->\n        <div class=\"carousel-card bg-white border-4 border-white flex flex-col rounded-[8px] shrink-0 w-[180px] overflow-hidden\">\n          <div class=\"relative h-[136px] rounded-[8px] overflow-hidden flex items-center justify-center p-2\"\n               style=\"background: radial-gradient(ellipse at 50% 50%, #ffffff 42%, #F5F7FA 100%)\">\n            <img src=\"img/sliders/aehnlich-wasserkocher-1.webp\"\n                 class=\"h-[112px] w-full object-contain pointer-events-none\" style=\"mix-blend-mode:multiply\" alt=\"Midea MKE17M1ADS\">\n          </div>\n          <div class=\"flex flex-col gap-1 pt-2 px-2 pb-2\">\n            <p class=\"text-[14px] font-medium text-link leading-[1.4]\" style=\"display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden\">Midea MKE17M1ADS</p>\n            <div class=\"flex items-center gap-1 h-[21px]\">\n              <span class=\"text-[12px] font-medium text-ink\">4,5</span>\n              <div class=\"flex 